# ── Server Environment Variables ─────────────────────────────────────────────

PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Local development
MONGODB_URI=mongodb://localhost:27017/petproject
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/petproject

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=your-strong-secret-here
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development
CORS_ORIGIN=http://localhost:5173
# Production (after Vercel deploy — replace with your actual Vercel domain)
# CORS_ORIGIN=https://your-frontend.vercel.app

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production
